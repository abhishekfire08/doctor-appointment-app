<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="background">#00272C</color>
    <color name="black">#000000</color>
    <color name="cancelled">#E5484D</color>
    <color name="completed">#2E9E6B</color>
    <color name="confirmed">#6AADB2</color>
    <color name="divider">#1A6A70</color>
    <color name="error">#E5484D</color>
    <color name="pending">#E09B3D</color>
    <color name="primary">#6AADB2</color>
    <color name="primary_dark">#44878C</color>
    <color name="primary_darker">#00555A</color>
    <color name="ripple">#2244878C</color>
    <color name="surface">#003B40</color>
    <color name="surface_variant">#00555A</color>
    <color name="text_hint">#6AADB2</color>
    <color name="text_on_primary">#00272C</color>
    <color name="text_primary">#E8F2F3</color>
    <color name="text_secondary">#9ECDD0</color>
    <color name="white">#FFFFFF</color>
    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:background">@drawable/bg_chip_unselected</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="FilterChipSelected" parent="FilterChip">
        <item name="android:background">@drawable/bg_chip_selected</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.DoctorApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="Theme.DoctorApp.Splash" parent="Theme.DoctorApp">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
    </style>
</resources>