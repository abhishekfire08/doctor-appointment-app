<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.doctorapp"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <permission
        android:name="com.example.doctorapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.doctorapp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.example.doctorapp.MyApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_placeholder_doctor"
        android:label="@string/app_name"
        android:testOnly="true"
        android:theme="@style/Theme.DoctorApp"
        android:usesCleartextTraffic="false" >
        <activity
            android:name="com.example.doctorapp.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.DoctorApp.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.example.doctorapp.ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.auth.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.main.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.doctor.DoctorsHomeActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.doctor.DoctorCategoriesActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.doctor.DoctorListActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.doctor.DoctorProfileActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.appointment.AppointmentBookingActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.appointment.AppointmentHistoryActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.records.MedicalRecordsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.notifications.NotificationsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name="com.example.doctorapp.ui.reviews.ReviewsActivity"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.doctorapp.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="okhttp3.internal.platform.PlatformInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>